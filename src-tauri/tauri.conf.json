{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GTNH Reactor Planner",
  "version": "0.1.0",
  "identifier": "dev.local.ic2-exp-reactor-planner-modern",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "GTNH Reactor Planner",
        "width": 1600,
        "height": 900,
        "minWidth": 1280,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"]
  }
}
